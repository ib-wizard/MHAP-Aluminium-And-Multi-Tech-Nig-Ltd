# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- PRODUCTION (Render) ---
# Set CLIENT_URL to your Render frontend Static Site URL, e.g.:
# CLIENT_URL=https://YOUR-FRONTEND-SERVICE.onrender.com

# PostgreSQL connection
# Either set DATABASE_URL, or the individual PGHOST/PGUSER/etc fields below
DATABASE_URL=postgresql://mhap_user:change_me@localhost:5432/mhap_aluminum
PGHOST=localhost
PGPORT=5432
PGDATABASE=mhap_aluminum
PGUSER=mhap_user
PGPASSWORD=change_me

# Set to true if your Postgres provider requires SSL (e.g. most managed clouds)
PGSSL=false

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=8h

# First admin account, created automatically the first time the server
# starts if the admin_users table is empty. Change the password after first login.
SEED_ADMIN_EMAIL=admin@mhapaluminum.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_USERNAME=admin

# File uploads
MAX_UPLOAD_MB=8
